; Engine configuration file.
; Sovereign's Reach — Godot 4.6.3
; Architecture: Multiplayer-First (MFA). Simulation autoloads own all game state.
; The View layer ONLY reads from autoloads — it never writes state directly.

[application]

config/name="Sovereign's Reach"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

EventBus="*res://simulation/core/EventBus.gd"
CommandQueue="*res://simulation/core/CommandQueue.gd"
SimulationClock="*res://simulation/core/SimulationClock.gd"
GameState="*res://simulation/core/GameState.gd"
InputSetup="*res://simulation/core/InputSetup.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
